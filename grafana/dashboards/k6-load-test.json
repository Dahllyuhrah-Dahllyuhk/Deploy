{
  "__inputs": [{ "name": "DS_PROMETHEUS", "type": "datasource", "pluginId": "prometheus" }],
  "title": "k6 Load Test Results",
  "uid": "k6-load-test",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1, "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "title": "HTTP 요청 처리량 (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "rate(k6_http_reqs_total[30s])",
        "legendFormat": "requests/s"
      }]
    },
    {
      "id": 2, "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "title": "HTTP 응답시간 (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "k6_http_req_duration_p50", "legendFormat": "p50" },
        { "expr": "k6_http_req_duration_p95", "legendFormat": "p95" },
        { "expr": "k6_http_req_duration_p99", "legendFormat": "p99" }
      ]
    },
    {
      "id": 3, "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "title": "Virtual Users (동시접속자)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "k6_vus", "legendFormat": "VUs" }]
    },
    {
      "id": 4, "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "title": "에러율",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(k6_http_req_failed_total[30s])", "legendFormat": "error rate" }]
    },
    {
      "id": 5, "type": "timeseries", "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "title": "Spring Boot HTTP 요청 처리량 (BE 실측)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(http_server_requests_seconds_count{application=\"matuabom\"}[30s])", "legendFormat": "{{uri}} {{status}}" }
      ]
    },
    {
      "id": 6, "type": "timeseries", "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "title": "Spring Boot 응답시간 p95 (BE 실측)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"matuabom\"}[30s])) by (le, uri))", "legendFormat": "p95 {{uri}}" }
      ]
    }
  ]
}
